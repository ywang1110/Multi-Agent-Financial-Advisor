# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-5.1          # options: gpt-5.1, gpt-5.3
LLM_TEMPERATURE=0.3

# ── Tools ─────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Knowledge Store ───────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=data/chroma_db
CHROMA_COLLECTION_NAME=financial_knowledge

# ── LangSmith Tracing ─────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=jpmc-investment-advisor

# ── Guardrails ────────────────────────────────────────────────────────────────
MAX_CONVERSATION_TURNS=10
